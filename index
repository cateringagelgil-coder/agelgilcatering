<style>

/* ====== COLORS ====== */
:root{
  --gold:#e90822;
  --black:#0e0e0e;
  --white:#ffffff;
  --gray:#f6f6f6;
}

/* ====== GLOBAL ====== */
*{box-sizing:border-box}
body{
  margin:0;
  font-family:'Inter',sans-serif;
  background:white;
  color:var(--black);
}
h1,h2,h3{
  font-family:'Playfair Display',serif;
}

/* ====== HEADER ====== */
header{
  background:linear-gradient(90deg,#d47171,#c5abab);
  color:white;
  padding:20px;
  text-align:center;
  position:sticky;
  top:0;
  z-index:1000;
}
header a{
  color:white;
  margin:0 10px;
  text-decoration:none;
  font-weight:700;
}
header a:hover{color:var(--gold)}

/* ====== HERO SLIDER ====== */
.hero-slider{
  position:relative;
  height:90vh;
  overflow:hidden;
}
.hero-slide{
  position:absolute;
  width:100%;
  height:100%;
  opacity:0;
  transition:opacity 1.5s ease;
}
.hero-slide.active{opacity:1}
.hero-slide img{
  width:100%;
  height:100%;
  object-fit:cover;
}
.hero-content{
  position:absolute;
  z-index:2;
  text-align:center;
  width:100%;
  top:50%;
  transform:translateY(-50%);
  color:white;
}
.hero-content h1{
  font-size:60px;
}
.btn{
  background:linear-gradient(135deg,#c9a227,#f5d76e);
  padding:15px 35px;
  border-radius:50px;
  text-decoration:none;
  color:black;
  font-weight:800;
  transition:.4s;
}
.btn:hover{transform:scale(1.08)}

/* ====== SECTIONS ====== */
section{
  padding:100px 20px;
}
.container{
  max-width:1200px;
  margin:auto;
}

/* ====== MENU ====== */
.grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
  gap:20px;
}
.card{
  background:white;
  border-radius:20px;
  box-shadow:0 15px 40px rgba(0,0,0,0.08);
  padding:20px;
  transition:.4s;
}
.card:hover{transform:translateY(-8px)}
.card img{
  width:100%;
  height:180px;
  object-fit:cover;
  border-radius:12px;
}

/* ====== CART ====== */
.cart{
  background:var(--gray);
  padding:25px;
  border-radius:20px;
  margin-top:30px;
}
.total{
  font-size:20px;
  font-weight:900;
}

/* ====== INSTAGRAM STYLE GALLERY ====== */
.gallery{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(200px,1fr));
  gap:5px;
}
.gallery img{
  width:100%;
  height:220px;
  object-fit:cover;
  transition:.4s;
  cursor:pointer;
}
.gallery img:hover{transform:scale(1.05)}


/* ====== VIDEO GALLERY ====== */
.video-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(320px,1fr));
  gap:40px;
  align-items:center;
  justify-items:center;
}

.video-grid video{
  width:100%;
  max-width:420px;
  height:500px;           /* makes all videos same height */
  object-fit:cover;       /* keeps it clean */
  border-radius:25px;
  box-shadow:0 20px 50px rgba(0,0,0,0.25);
  transition:0.4s ease;
}

.video-grid video:hover{
  transform:scale(1.05);
}
/* ====== LIGHTBOX ====== */
.lightbox{
  display:none;
  position:fixed;
  inset:0;
  background:rgba(0,0,0,0.9);
  justify-content:center;
  align-items:center;
  z-index:2000;
}
.lightbox img{
  max-width:90%;
  max-height:90%;
  border-radius:15px;
}

/* ====== FOOTER ====== */
footer{
  background:var(--black);
  color:white;
  text-align:center;
  padding:40px;
}
footer a{
  color:white;
  margin:0 10px;
  text-decoration:none;
  font-weight:800;
}
footer a:hover{color:var(--gold)}
.slider{
  overflow:hidden;
  background:var(--gray);
  padding:40px;
  border-radius:20px;
  text-align:center;
}

.slides{
  display:flex;
  transition:transform 0.6s ease;
}

.slide{
  min-width:100%;
}
/* ====== WHATSAPP ====== */
.whatsapp{
  position:fixed;
  bottom:20px;
  right:20px;
  background:#25D366;
  color:white;
  padding:14px 18px;
  border-radius:50px;
  font-weight:900;
  text-decoration:none;
}

@media(max-width:600px){
  .hero-content h1{font-size:32px}
}

</style>
</head>

